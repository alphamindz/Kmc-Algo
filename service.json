{
  "$schema": "https://northflank.com/schemas/service.json",
  "name": "kmc-algo",
  "description": "Adaptive RL environment for aligned intelligence",
  "billing": {
    "deploymentPlan": "nf-compute-200"
  },
  "deployment": {
    "docker": {
      "configType": "default"
    }
  },
  "ports": [
    {
      "name": "api",
      "internalPort": 7860,
      "protocol": "HTTP",
      "public": true
    },
    {
      "name": "demo",
      "internalPort": 7861,
      "protocol": "HTTP",
      "public": true
    }
  ],
  "environmentVariables": [
    {
      "key": "KMC_ALGO",
      "value": "all"
    }
  ]
}
